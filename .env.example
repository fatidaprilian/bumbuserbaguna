# Application
APP_ENV=development
APP_PORT=3000
APP_NAME=Bumbuserbaguna

# Database — matches docker-compose.dev.yml
DATABASE_URL=postgresql://bumbu:localdev@localhost:5432/bumbuserbaguna

# Cache / Queue (optional in Phase 1 — required in Phase 3)
REDIS_URL=redis://localhost:6379

# Object Storage (optional in Phase 1)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=documents
STORAGE_ACCESS_KEY=replace_me
STORAGE_SECRET_KEY=replace_me

# Auth — use at least 32 character random strings
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_min_32_chars_random_secret_here_dev
JWT_REFRESH_SECRET=replace_me_min_32_chars_random_secret_here_dev2
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# AI Gateway (optional in Phase 1)
AI_GATEWAY_TIMEOUT_MS=15000
AI_MONTHLY_BUDGET_USD=200
AI_PRIMARY_PROVIDER=selfhost
AI_FALLBACK_PROVIDER=none

# External AI provider (optional)
EXTERNAL_AI_API_KEY=replace_me
EXTERNAL_AI_BASE_URL=https://api.example.com
