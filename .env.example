# Application
APP_ENV=development
APP_PORT=3000
APP_NAME=Bumbuserbaguna

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/bumbuserbaguna

# Cache / Queue
REDIS_URL=redis://localhost:6379

# Object Storage
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=documents
STORAGE_ACCESS_KEY=replace_me
STORAGE_SECRET_KEY=replace_me

# Auth
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# AI Gateway
AI_GATEWAY_TIMEOUT_MS=15000
AI_MONTHLY_BUDGET_USD=200
AI_PRIMARY_PROVIDER=selfhost
AI_FALLBACK_PROVIDER=external

# External provider placeholders (optional)
EXTERNAL_AI_API_KEY=replace_me
EXTERNAL_AI_BASE_URL=https://api.example.com
